<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.WeatherWatch" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">#1565C0</item>
        <item name="colorPrimaryVariant">#0D47A1</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <item name="colorSecondary">#0EA5E9</item>
        <item name="colorOnSecondary">#FFFFFF</item>
        <item name="colorSurface">#FFFFFF</item>
        <item name="colorOnSurface">#1E293B</item>
        <item name="colorOutline">#E2E8F0</item>
        <item name="android:colorBackground">#F0F4F8</item>
        <item name="android:statusBarColor">#0D47A1</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <style name="ToolbarTitleAppearance" parent="TextAppearance.Widget.AppCompat.Toolbar.Title">
        <item name="android:textSize">26sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">#FFFFFF</item>
    </style>

    <!-- Tile u DETALJI kartici -->
    <style name="DetaljTile">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:orientation">vertical</item>
        <item name="android:background">@drawable/bg_detalj_kartica</item>
        <item name="android:padding">14dp</item>
    </style>

    <style name="DetaljLabel">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textColor">@color/ww_text_secondary</item>
    </style>

    <style name="DetaljValue">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">17sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/ww_text_primary</item>
        <item name="android:layout_marginTop">6dp</item>
    </style>

    <!-- Postavke -->
    <style name="SettingsSekcija">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">13sp</item>
        <item name="android:letterSpacing">0.08</item>
        <item name="android:textColor">@color/ww_text_muted</item>
        <item name="android:layout_marginBottom">12dp</item>
    </style>

    <style name="SettingsRadio">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:textColor">@color/ww_text_primary</item>
        <item name="android:textSize">15sp</item>
    </style>
</resources>
